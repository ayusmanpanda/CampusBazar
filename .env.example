# Shared by both backends — copy to server/.env (Node) or server-springboot/.env (Spring Boot).

# Common
PORT=5000
MONGO_URI=your_mongodb_atlas_uri
JWT_SECRET=replace-with-32-byte-random-string
JWT_REFRESH_SECRET=replace-with-different-32-byte-random-string
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
REDIS_URL=your_upstash_redis_url           # optional — both backends run without it
COLLEGE_EMAIL_DOMAIN=college.edu.in
CLIENT_URL=http://localhost:3000
